{% extends 'base.html.twig' %}
{% block title %}Inscription - Les patounes du glazik{% endblock %}
{% block stylesheets %}{{ parent() }}<link rel="stylesheet" href="{{ asset('build/app.css') }}">{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-card" style="max-width:460px;">
        <div class="login-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Les patounes du glazik">
        </div>
        <h1 class="login-title">Créer un compte</h1>

        {% if error %}
            <div class="login-error">{{ error }}</div>
        {% endif %}

        <form method="post" class="login-form">
            <input type="hidden" name="_token" value="{{ csrf_token('register') }}">
            <div class="form-row">
                <div class="form-group">
                    <label for="firstName">Prénom *</label>
                    <input type="text" id="firstName" name="firstName" required placeholder="Prénom">
                </div>
                <div class="form-group">
                    <label for="lastName">Nom *</label>
                    <input type="text" id="lastName" name="lastName" required placeholder="Nom de famille">
                </div>
            </div>
            <div class="form-group">
                <label for="email">Email *</label>
                <input type="email" id="email" name="email" required placeholder="votre@email.com">
            </div>
            <div class="form-group">
                <label for="phone">Téléphone *</label>
                <input type="tel" id="phone" name="phone" required placeholder="06 12 34 56 78" autocomplete="tel">
                <p class="register-field-hint">Utilisé par Sophie pour vous recontacter lors de vos réservations (SMS, appel ou WhatsApp). Aucune newsletter ne sera envoyée. Votre numéro n'est jamais partagé.</p>
            </div>
            <div class="form-group">
                <label for="username">Pseudo *</label>
                <input type="text" id="username" name="username" required placeholder="ex : ChatNoir42" minlength="3">
                <p class="register-field-hint">
                    Votre pseudo sera affiché publiquement à la place de votre vrai nom, notamment lors de vos commentaires.
                    Choisissez-le librement pour préserver votre vie privée.
                </p>
            </div>
            <div class="form-group">
                <label for="password">Mot de passe * (8 caractères minimum)</label>
                <div class="input-password-wrap">
                    <input type="password" id="password" name="password" required autocomplete="new-password">
                    <button type="button" class="btn-eye" data-target="password" aria-label="Afficher le mot de passe">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label for="confirm">Confirmer le mot de passe *</label>
                <div class="input-password-wrap">
                    <input type="password" id="confirm" name="confirm" required autocomplete="new-password">
                    <button type="button" class="btn-eye" data-target="confirm" aria-label="Afficher le mot de passe">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
            </div>

            <label class="form-check">
                <input type="checkbox" name="acceptCgu" id="acceptCgu" required>
                <span>
                    J'ai lu et j'accepte les
                    <a href="{{ path('app_legal_cgu') }}" target="_blank">Conditions Générales d'Utilisation</a>
                    et la
                    <a href="{{ path('app_legal_privacy') }}" target="_blank">Politique de confidentialité</a>.
                </span>
            </label>

            <button type="submit" class="btn btn-submit" style="width:100%;justify-content:center;">Créer mon compte</button>
        </form>

        <div class="login-divider"><span>ou s'inscrire avec</span></div>

        <div class="oauth-buttons">
            <a href="{{ path('app_oauth_google_connect') }}" class="btn-oauth btn-oauth--google">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Google
            </a>
            <a href="{{ path('app_oauth_facebook_connect') }}" class="btn-oauth btn-oauth--facebook">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
                </svg>
                Facebook
            </a>
        </div>

        <a href="{{ path('app_member_login') }}" class="login-back">Déjà inscrit ? Se connecter</a>

        <div class="login-footer-links">
            <a href="{{ path('app_legal_cgu') }}">CGU</a>
            <span>·</span>
            <a href="{{ path('app_legal_privacy') }}">Confidentialité</a>
            <span>·</span>
            <span>© 2026 Les patounes du Glazik</span>
            <span>·</span>
            <a href="https://by-tom.fr/" target="_blank" rel="noopener noreferrer">byTom</a>
        </div>
    </div>
</div>
<script>
(function () {
    document.querySelectorAll('.btn-eye').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(this.dataset.target);
            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            this.querySelector('.eye-open').style.display = isPassword ? 'none' : '';
            this.querySelector('.eye-closed').style.display = isPassword ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
