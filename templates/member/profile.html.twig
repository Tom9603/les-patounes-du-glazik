{% extends 'base.html.twig' %}
{% block title %}Mon profil - Les patounes du glazik{% endblock %}
{% block stylesheets %}{{ parent() }}<link rel="stylesheet" href="{{ asset('build/app.css') }}">{% endblock %}

{% block body %}
<div class="page-wrapper">

    <nav class="navbar">
        <div class="container navbar-content">
            <div class="navbar-brand">
                <div class="logo-circle">
                    <img src="{{ asset('images/logo.png') }}" alt="Les patounes du glazik" class="logo-img">
                </div>
                <div class="brand-text">
                    <a href="{{ path('app_home') }}" class="brand-title" style="text-decoration:none;color:inherit;">Les patounes du glazik</a>
                    <p class="brand-subtitle">Petsitting & Naturopathie animalière</p>
                </div>
            </div>
            <nav class="nav-links">
                <a href="{{ path('app_home') }}#services" class="nav-link">Services</a>
                <a href="{{ path('app_home') }}#tarifs" class="nav-link">Tarifs</a>
                <a href="{{ path('app_blog') }}" class="nav-link">Blog</a>
                <a href="{{ path('app_home') }}#contact" class="nav-link">Contact</a>
            </nav>
            <div class="navbar-actions">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin') }}" class="btn btn-admin">Administrer</a>
                {% endif %}
                <a href="{{ path('app_profile') }}" class="btn btn-profile btn-profile--active">
                    {% if member.avatarFilename %}
                        <img src="{{ asset('uploads/avatars/' ~ member.avatarFilename) }}" alt="" class="avatar-mini">
                    {% else %}
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                            <circle cx="12" cy="7" r="4"/>
                        </svg>
                    {% endif %}
                    <span>Profil</span>
                </a>
            </div>
        </div>
    </nav>

    <div class="profile-page">
        <div class="container">

            {# Flash messages #}
            {% for msg in app.flashes('success') %}
                <div class="profile-flash profile-flash--success">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    {{ msg }}
                </div>
            {% endfor %}
            {% for msg in app.flashes('error') %}
                <div class="profile-flash profile-flash--error">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    {{ msg }}
                </div>
            {% endfor %}

            {# Profile header #}
            <div class="profile-hero">
                <div class="profile-avatar-wrapper">
                    {% if member.avatarFilename %}
                        <img src="{{ asset('uploads/avatars/' ~ member.avatarFilename) }}" alt="Avatar" class="profile-avatar-img">
                    {% else %}
                        <div class="profile-avatar-placeholder">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                                <circle cx="12" cy="7" r="4"/>
                            </svg>
                        </div>
                    {% endif %}
                </div>
                <div class="profile-hero-info">
                    <h1 class="profile-name">{{ member.firstName }}</h1>
                    <p class="profile-email">{{ member.email }}</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="profile-badge badge-admin">Administrateur</span>
                    {% else %}
                        <span class="profile-badge badge-member">Membre</span>
                    {% endif %}
                    <p class="profile-member-since">Membre depuis le {{ member.createdAt|date('d/m/Y') }}</p>
                </div>
            </div>

            {# Grid #}
            <div class="profile-grid">

                {# Mon compte #}
                <div class="profile-card">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        Mon compte
                    </h2>
                    <form method="post" action="{{ path('app_profile_update') }}" enctype="multipart/form-data" class="profile-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile-info') }}">

                        <div class="profile-avatar-upload-row">
                            <div id="avatar-preview-wrap">
                                {% if member.avatarFilename %}
                                    <img id="avatar-preview-img" src="{{ asset('uploads/avatars/' ~ member.avatarFilename) }}" alt="Avatar" class="avatar-upload-preview">
                                {% else %}
                                    <div id="avatar-preview-placeholder" class="avatar-upload-placeholder">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="avatar-upload-actions">
                                <label for="avatar-file-input" class="btn-avatar-change">Changer la photo</label>
                                <input type="file" id="avatar-file-input" name="avatar"
                                       accept="image/jpeg,image/jpg,image/png,image/webp,image/gif,image/bmp"
                                       style="display:none">
                                <p class="avatar-hint">JPEG, PNG, WEBP, GIF, BMP. Max 10 Mo.<br>Recadrée automatiquement en carré 300x300 px.</p>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="firstName">Prénom</label>
                                <input type="text" id="firstName" name="firstName" value="{{ member.firstName }}" required>
                            </div>
                            <div class="form-group">
                                <label for="lastName">Nom</label>
                                <input type="text" id="lastName" name="lastName" value="{{ member.lastName ?? '' }}">
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="username">Pseudo (affiché sur les commentaires)</label>
                            <input type="text" id="username" name="username" value="{{ member.username ?? '' }}" placeholder="ex : ChatNoir42" minlength="3">
                            <span class="register-field-hint">Visible publiquement. Laissez vide pour utiliser votre prénom.</span>
                        </div>
                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" value="{{ member.email }}" required>
                        </div>
                        <div class="profile-form-actions">
                            <button type="submit" class="btn-profile-save">Enregistrer</button>
                        </div>
                    </form>
                </div>

                {# Sécurité #}
                <div class="profile-card">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        Sécurité
                    </h2>
                    <form method="post" action="{{ path('app_profile_password') }}" class="profile-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile-password') }}">
                        <div class="form-group">
                            <label for="currentPassword">Mot de passe actuel</label>
                            <div class="input-password-wrap">
                                <input type="password" id="currentPassword" name="currentPassword" required autocomplete="current-password">
                                <button type="button" class="btn-eye" data-target="currentPassword" aria-label="Afficher">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="newPassword">Nouveau mot de passe (8 caractères minimum)</label>
                            <div class="input-password-wrap">
                                <input type="password" id="newPassword" name="newPassword" required autocomplete="new-password">
                                <button type="button" class="btn-eye" data-target="newPassword" aria-label="Afficher">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="confirmPassword">Confirmer le nouveau mot de passe</label>
                            <div class="input-password-wrap">
                                <input type="password" id="confirmPassword" name="confirmPassword" required autocomplete="new-password">
                                <button type="button" class="btn-eye" data-target="confirmPassword" aria-label="Afficher">
                                    <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                                </button>
                            </div>
                        </div>
                        <div class="profile-form-actions">
                            <button type="submit" class="btn-profile-save">Modifier le mot de passe</button>
                        </div>
                    </form>
                </div>

                {% if not is_granted('ROLE_ADMIN') %}
                {# Mes animaux #}
                <div class="profile-card profile-card--full">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.96-1.45-2.344-2.5"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5"/></svg>
                        Mes animaux
                    </h2>

                    {% set animals = member.animals %}
                    {% if animals|length > 0 %}
                    <div class="animals-list">
                        {% for animal in animals %}
                        <div class="animal-card">
                            <div class="animal-card-header">
                                <span class="animal-species-badge">{{ animal.species.label() }}</span>
                                <strong class="animal-name">{{ animal.name }}</strong>
                                {% if animal.breed %}<span class="animal-breed">{{ animal.breed }}</span>{% endif %}
                            </div>
                            <div class="animal-card-details">
                                {% if animal.sex %}<span>{{ animal.sex.label() }}</span>{% endif %}
                                {% if animal.birthDate %}<span>Né(e) le {{ animal.birthDate|date('d/m/Y') }}</span>{% endif %}
                                {% if animal.sterilized %}<span class="animal-sterilized">Stérilisé(e)</span>{% endif %}
                            </div>
                            <div class="animal-card-actions">
                                <a href="{{ path('app_animal_edit', { id: animal.id }) }}" class="btn-animal-edit">Modifier</a>
                                <form method="post" action="{{ path('app_animal_delete', { id: animal.id }) }}" class="inline-form" onsubmit="return confirm('Supprimer {{ animal.name }} ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('animal-delete-' ~ animal.id) }}">
                                    <button type="submit" class="btn-animal-delete">Supprimer</button>
                                </form>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="placeholder-section">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.96-1.45-2.344-2.5"/></svg>
                        <p>Vous n'avez pas encore d'animal enregistré.</p>
                        <small>Ajoutez vos animaux pour faciliter vos demandes de réservation.</small>
                    </div>
                    {% endif %}

                    <div class="profile-form-actions" style="margin-top:1.25rem;">
                        <a href="{{ path('app_animal_new') }}" class="btn-profile-save">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:1em;height:1em;vertical-align:-0.1em;margin-right:0.4em;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Ajouter un animal
                        </a>
                    </div>
                </div>

                {# Mes réservations #}
                <div class="profile-card profile-card--full">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        Mes réservations
                    </h2>

                    {% set bookings = member.bookings %}
                    {% if bookings|length > 0 %}
                    <div class="bookings-list">
                        {% for booking in bookings|sort((a, b) => b.createdAt <=> a.createdAt) %}
                        <div class="booking-item booking-item--{{ booking.status.value }}">
                            <div class="booking-item-header">
                                <span class="booking-status-badge {{ booking.status.badgeClass() }}">{{ booking.status.label() }}</span>
                                <span class="booking-service">{{ booking.serviceType.label() }}</span>
                                <span class="booking-date">Demandé le {{ booking.createdAt|date('d/m/Y') }}</span>
                            </div>
                            <div class="booking-item-details">
                                <span>Date souhaitée : {{ booking.preferredDate|date('d/m/Y') }}{% if booking.preferredTime %} à {{ booking.preferredTime }}{% endif %}</span>
                                {% if booking.scheduledAt %}
                                    <span class="booking-scheduled">RDV confirmé : {{ booking.scheduledAt|date('d/m/Y à H:i') }}</span>
                                {% endif %}
                                {% if booking.animal %}
                                    <span>Animal : {{ booking.animal.name }}</span>
                                {% endif %}
                                {% if booking.price %}
                                    <span>Tarif : {{ booking.price|number_format(2, ',', ' ') }} €</span>
                                {% endif %}
                            </div>
                            {% if booking.adminNotes and booking.status.value in ['confirmed', 'refused'] %}
                            <div class="booking-item-notes">
                                <strong>Message de Sophie :</strong> {{ booking.adminNotes }}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="placeholder-section">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <p>Vous n'avez pas encore de réservation.</p>
                        <small>Vos prochains rendez-vous apparaîtront ici une fois réservés.</small>
                    </div>
                    {% endif %}

                    <div class="profile-form-actions" style="margin-top:1.25rem;">
                        {% if member.isVerified %}
                            <a href="{{ path('app_booking_new') }}" class="btn-profile-save">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:1em;height:1em;vertical-align:-0.1em;margin-right:0.4em;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Faire une réservation
                            </a>
                        {% else %}
                            <p style="color:#e89a5c;font-size:0.9rem;">Vérifiez votre adresse email pour pouvoir réserver.</p>
                        {% endif %}
                    </div>
                </div>
                {% endif %}

                {# Déconnexion #}
                <div class="profile-card">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Déconnexion
                    </h2>
                    <p style="color:#6b7768;font-size:0.9rem;margin-bottom:1.25rem;line-height:1.6;">
                        Vous serez redirigé vers la page d'accueil après déconnexion.
                    </p>
                    <a href="{{ path('app_member_logout') }}" class="btn-logout">
                        <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                            <polyline points="16 17 21 12 16 7"/>
                            <line x1="21" y1="12" x2="9" y2="12"/>
                        </svg>
                        Se déconnecter
                    </a>
                </div>

                {% if not is_granted('ROLE_ADMIN') %}
                {# Zone de danger #}
                <div class="profile-card profile-card--danger">
                    <h2>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="card-icon"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Supprimer mon compte
                    </h2>
                    <p style="color:#6b7768;font-size:0.9rem;margin-bottom:1.25rem;line-height:1.6;">
                        Cette action est définitive et irréversible. Toutes vos données seront supprimées immédiatement.
                    </p>
                    <form method="post" action="{{ path('app_profile_delete') }}" id="delete-account-form">
                        <input type="hidden" name="_token" value="{{ csrf_token('profile-delete') }}">
                        <button type="button" class="btn-danger" onclick="confirmDelete()">Supprimer mon compte</button>
                    </form>
                </div>
                {% endif %}

            </div>
        </div>
    {% include 'partials/_footer.html.twig' %}
</div>

<script>
(function () {
    document.querySelectorAll('.btn-eye').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(this.dataset.target);
            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            this.querySelector('.eye-open').style.display = isPassword ? 'none' : '';
            this.querySelector('.eye-closed').style.display = isPassword ? '' : 'none';
        });
    });
})();

function confirmDelete() {
    if (confirm('Êtes-vous certain de vouloir supprimer définitivement votre compte ? Cette action est irréversible.')) {
        document.getElementById('delete-account-form').submit();
    }
}

(function () {
    const input = document.getElementById('avatar-file-input');
    if (!input) return;
    input.addEventListener('change', function () {
        if (!this.files || !this.files[0]) return;
        const reader = new FileReader();
        reader.onload = function (e) {
            const wrap = document.getElementById('avatar-preview-wrap');
            wrap.innerHTML = '<img id="avatar-preview-img" src="' + e.target.result + '" alt="Preview" class="avatar-upload-preview">';
        };
        reader.readAsDataURL(this.files[0]);
    });
})();
</script>
{% endblock %}
