{% extends 'base.html.twig' %}
{% block title %}Nouveau mot de passe - Les patounes du glazik{% endblock %}
{% block stylesheets %}{{ parent() }}<link rel="stylesheet" href="{{ asset('build/app.css') }}">{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Les patounes du glazik">
        </div>
        <h1 class="login-title">Nouveau mot de passe</h1>

        {% if error %}
            <div class="login-error">{{ error }}</div>
        {% endif %}

        <form method="post" class="login-form" style="width:100%;">
            <div class="form-group">
                <label for="password">Nouveau mot de passe (8 caractères minimum)</label>
                <div class="input-password-wrap">
                    <input type="password" id="password" name="password" required autocomplete="new-password">
                    <button type="button" class="btn-eye" data-target="password" aria-label="Afficher le mot de passe">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
            </div>
            <div class="form-group">
                <label for="confirm">Confirmer le mot de passe</label>
                <div class="input-password-wrap">
                    <input type="password" id="confirm" name="confirm" required autocomplete="new-password">
                    <button type="button" class="btn-eye" data-target="confirm" aria-label="Afficher le mot de passe">
                        <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-submit" style="width:100%;justify-content:center;">Réinitialiser le mot de passe</button>
        </form>

        <div class="login-footer-links">
            <a href="{{ path('app_legal_cgu') }}">CGU</a>
            <span>·</span>
            <a href="{{ path('app_legal_privacy') }}">Confidentialité</a>
            <span>·</span>
            <span>© 2026 Les patounes du Glazik</span>
            <span>·</span>
            <a href="https://by-tom.fr/" target="_blank" rel="noopener noreferrer">byTom</a>
        </div>
    </div>
</div>
<script>
(function () {
    document.querySelectorAll('.btn-eye').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var input = document.getElementById(this.dataset.target);
            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            this.querySelector('.eye-open').style.display = isPassword ? 'none' : '';
            this.querySelector('.eye-closed').style.display = isPassword ? '' : 'none';
        });
    });
})();
</script>
{% endblock %}
