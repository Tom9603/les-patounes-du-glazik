{% extends 'base.html.twig' %}
{% block title %}Connexion - Les patounes du glazik{% endblock %}
{% block stylesheets %}{{ parent() }}<link rel="stylesheet" href="{{ asset('build/app.css') }}">{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <img src="{{ asset('images/logo.png') }}" alt="Les patounes du glazik">
        </div>
        <h1 class="login-title">Se connecter</h1>

        {% if error %}
            <div class="login-error">Email ou mot de passe incorrect.</div>
        {% endif %}

        {% for flash in app.flashes('success') %}
            <div style="background:rgba(125,140,111,.1);border:1px solid rgba(125,140,111,.3);border-radius:8px;padding:.75rem 1rem;color:#7d8c6f;font-size:.9rem;margin-bottom:1rem;">{{ flash }}</div>
        {% endfor %}

        <form method="post" class="login-form">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="text" id="email" name="_username" value="{{ last_username }}" required autocomplete="username">
            </div>
            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" required autocomplete="current-password">
            </div>
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn btn-submit" style="width:100%;justify-content:center;">Se connecter</button>
        </form>

        <div class="login-divider"><span>ou continuer avec</span></div>

        <div class="oauth-buttons">
            <a href="{{ path('app_oauth_google_connect') }}" class="btn-oauth btn-oauth--google">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Google
            </a>
            <a href="{{ path('app_oauth_facebook_connect') }}" class="btn-oauth btn-oauth--facebook">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/>
                </svg>
                Facebook
            </a>
        </div>

        <a href="{{ path('app_register') }}" class="login-back">Pas encore inscrit ? Créer un compte</a>
        <a href="{{ path('app_home') }}" class="login-back" style="font-size:0.8rem;color:#aaa;">Retour au site</a>
    </div>
</div>
{% endblock %}
