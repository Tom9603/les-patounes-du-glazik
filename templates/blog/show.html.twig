{% extends 'base.html.twig' %}

{% block title %}{{ article.title }} - Les patounes du glazik{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/app.css') }}">
{% endblock %}

{% block body %}
<div class="page-wrapper">

    {% include 'partials/_navbar.html.twig' %}

    <div class="article-page">
        <div class="container-small">

            <div class="article-breadcrumb">
                <a href="{{ path('app_blog') }}">Blog</a>
                <span>/</span>
                <span>{{ article.title }}</span>
            </div>

            <article class="article-content">
                {% if article.category %}
                    <span class="blog-card-category">{{ article.category.name }}</span>
                {% endif %}

                <h1 class="article-title">{{ article.title }}</h1>

                {% if article.featuredImageFilename %}
                    <img src="/uploads/articles/{{ article.featuredImageFilename }}" alt="{{ article.title }}" class="article-cover-img">
                {% endif %}

                <div class="article-meta">
                    <span>{{ article.publishedAt ? article.publishedAt|date('d/m/Y') : '' }}</span>
                    <span>{{ article.approvedComments|length }} commentaire{{ article.approvedComments|length != 1 ? 's' : '' }}</span>
                    {% if is_granted('ROLE_ADMIN') %}
                        <span class="article-views">{{ article.viewCount }} vue{{ article.viewCount != 1 ? 's' : '' }}</span>
                    {% endif %}
                </div>

                <div class="article-body">
                    {{ article.content|raw }}
                </div>
            </article>

            <section class="comments-section">
                <h2 class="comments-title">Commentaires ({{ article.approvedComments|length }})</h2>

                {% for flash in app.flashes('success') %}
                    <div class="comment-flash">{{ flash }}</div>
                {% endfor %}

                {% if article.approvedComments is empty %}
                    <p class="comments-empty">Soyez le premier à commenter !</p>
                {% else %}
                    <div class="comments-list">
                        {% for comment in article.approvedComments %}
                            <div class="comment">
                                <div class="comment-header">
                                    <span class="comment-author">{{ comment.authorName }}</span>
                                    <span class="comment-date">{{ comment.createdAt|date('d/m/Y') }}</span>
                                </div>
                                <p class="comment-body">{{ comment.content }}</p>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="comment-form-section">
                    <h3 class="comment-form-title">Laisser un commentaire</h3>

                    {% if app.user and app.user.verified %}
                        <p class="comment-as">Vous commentez en tant que <strong>{{ app.user.firstName }}</strong></p>
                        <form method="POST" action="{{ path('app_blog_comment', {slug: article.slug}) }}" class="comment-form">
                            <div class="form-group">
                                <label for="comment-content">Commentaire *</label>
                                <textarea id="comment-content" name="content" rows="4" required placeholder="Votre message..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-submit">Publier mon commentaire</button>
                        </form>
                        <p class="comment-moderation-note">Les commentaires sont modérés avant publication.</p>

                    {% elseif app.user and not app.user.verified %}
                        <div class="comment-gate">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            <p>Vérifiez votre adresse email pour pouvoir commenter. Consultez votre boite de réception.</p>
                        </div>

                    {% else %}
                        <div class="comment-gate">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <p>Vous devez être connecté pour laisser un commentaire.</p>
                            <div class="comment-gate-actions">
                                <a href="{{ path('app_member_login') }}" class="btn btn-submit" style="padding:.65rem 1.4rem;font-size:.9rem;">Se connecter</a>
                                <a href="{{ path('app_register') }}" class="btn-gate-register">Créer un compte</a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </section>

        </div>
    </div>

    {% include 'partials/_footer.html.twig' %}

</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('build/animations.js') }}"></script>
{% endblock %}
