{% extends 'base.html.twig' %}

{% block title %}Les patounes du glazik - Petsitting & Naturopathie animalière{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/app.css') }}">
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <!-- Navigation -->
    {% include 'partials/_navbar.html.twig' %}

    <!-- Hero Section -->
    <section class="hero" id="hero">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-content fade-in-left">
                    <h2 class="hero-title">
                        Prenez soin de vos compagnons avec
                        <span class="text-primary">amour</span> et
                        <span class="text-secondary">professionnalisme</span>
                    </h2>
                    <p class="hero-description">
                        Je me déplace chez vous dans le secteur de Landudal et alentours (rayon 20 km)
                    </p>
                    <div class="hero-info">
                        <div class="info-item">
                            <svg class="icon icon-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                <circle cx="12" cy="10" r="3"/>
                            </svg>
                            <span>Landudal et alentours (rayon 20 km)</span>
                        </div>
                        <div class="info-item">
                            <svg class="icon icon-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="10"/>
                                <polyline points="12 6 12 12 16 14"/>
                            </svg>
                            <span>Disponible 7j/7 &middot; 8h30&ndash;19h30</span>
                        </div>
                    </div>
                    <div class="hero-tags">
                        <span class="hero-tag">Chiens & chats</span>
                        <span class="hero-tag">NAC</span>
                        <span class="hero-tag">Equidés</span>
                        <span class="hero-tag">Mini-ferme</span>
                        <span class="hero-tag hero-tag--accent">Assurance professionnelle</span>
                        <span class="hero-tag hero-tag--accent">ACACED certifiée</span>
                        <span class="hero-tag hero-tag--accent">Naturopathie animale</span>
                    </div>
                    <div class="hero-socials">
                        <a href="https://www.facebook.com/p/Sophie-Lukomski-Pet-Sitting-et-naturopathie-61553239394499/" target="_blank" rel="noopener noreferrer" class="hero-social-link" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                            </svg>
                        </a>
                        <a href="https://www.instagram.com/naturo_n_co/" target="_blank" rel="noopener noreferrer" class="hero-social-link" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                            </svg>
                        </a>
                    </div>
                </div>
                <div class="hero-image fade-in-right">
                    <img
                        src="{{ asset('images/heroPicture.png') }}"
                        alt="Sophie avec un Maine Coon"
                        class="main-image"
                    >
                    <div class="hero-badge">
                        <div class="stars">
                            {% for i in 1..5 %}
                                <svg class="star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                </svg>
                            {% endfor %}
                        </div>
                        <p class="badge-text">Plus de 30 clients satisfaits</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- À propos + carousel intégré -->
    <section class="about-section" id="a-propos">
        <div class="container">
            <div class="about-grid{% if photos is not empty %} about-grid--carousel{% endif %}">

                {# Colonne gauche : photo de Sophie (toujours présente) #}
                <div class="about-image animate-on-scroll">
                    <img src="{{ asset('images/heroPicture.png') }}" alt="Sophie, petsitter et naturopathe animalière" class="about-img">
                </div>

                {# Colonne centrale : texte Qui suis-je #}
                <div class="about-content animate-on-scroll">
                    <h3 class="section-title">Qui suis-je ?</h3>
                    <p class="about-text">Je m'appelle Sophie, passionnée par les animaux depuis toujours. Basée à Landudal en Finistère, je me déplace chez vous pour prendre soin de vos compagnons - parce qu'un animal est toujours mieux dans son environnement familier.</p>
                    <p class="about-text">Titulaire de l'ACACED (chien, chat, NAC) et formée en naturopathie animale à l'ENA MNC, j'interviens avec les garanties d'une professionnelle : assurée en responsabilité civile, déclarée auprès de la DDPP, avec médiateur agréé.</p>
                    <div class="about-badges">
                        <span class="about-badge">ACACED chien, chat, NAC</span>
                        <span class="about-badge">ENA MNC</span>
                    </div>
                </div>

                {# Colonne droite : carousel (seulement si des photos existent) #}
                {% if photos is not empty %}
                <div class="about-carousel-col">
                    <div class="carousel" id="photoCarousel">
                        <div class="carousel-track" id="carouselTrack">
                            {% for photo in photos %}
                            <div class="carousel-slide">
                                <img
                                    src="{{ asset('uploads/photos/' ~ photo.filename) }}"
                                    alt="{{ photo.alt ?? 'Photo - Les patounes du glazik' }}"
                                    loading="lazy"
                                >
                            </div>
                            {% endfor %}
                        </div>
                        <button class="carousel-btn carousel-btn--prev" id="carouselPrev" aria-label="Photo précédente">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        </button>
                        <button class="carousel-btn carousel-btn--next" id="carouselNext" aria-label="Photo suivante">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                        </button>
                    </div>
                    <div class="carousel-dots" id="carouselDots"></div>
                </div>
                {% endif %}

            </div>
        </div>
    </section>

    <!-- Bloc condensé : 3 piliers -->
    <section class="features-strip">
        <div class="container">
            <div class="features-strip-grid">

                {# Rangée 1 : icônes #}
                <div class="feature-strip-icon animate-on-scroll">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/></svg>
                </div>
                <div class="feature-strip-icon animate-on-scroll" style="--delay:.08s">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                </div>
                <div class="feature-strip-icon animate-on-scroll" style="--delay:.16s">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>

                {# Rangée 2 : titres #}
                <h4 class="feature-strip-title">Pour tous vos animaux</h4>
                <h4 class="feature-strip-title">A votre domicile</h4>
                <h4 class="feature-strip-title">En toute sécurité</h4>

                {# Rangée 3 : listes #}
                <ul class="feature-strip-list">
                    <li>Chiens & chats</li>
                    <li>NAC : lapins, reptiles...</li>
                    <li>Equidés</li>
                    <li>Mini-ferme : poules, chèvres...</li>
                </ul>
                <ul class="feature-strip-list">
                    <li>Vacances & week-end</li>
                    <li>Journées de travail</li>
                    <li>Hospitalisation</li>
                </ul>
                <ul class="feature-strip-list">
                    <li>ACACED, assurance, médiateur</li>
                    <li>Déclarée DDPP & BNO</li>
                    <li>Comportements équin & félin</li>
                    <li>Nutrition & naturopathie animale</li>
                </ul>

                {# Rangée 4 : notes — toujours à la même hauteur #}
                <p class="feature-strip-note">Je m'adapte à leur personnalité, leur âge et leurs besoins.</p>
                <p class="feature-strip-note">Vos animaux gardent leurs repères, sans stress.</p>
                <p class="feature-strip-note">Toutes les garanties d'une professionnelle.</p>

            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services-section" id="services">
        <div class="container">
            <div class="section-header animate-on-scroll">
                <h3 class="section-title">Mes services</h3>
                <p class="section-subtitle">Des prestations adaptées à vos besoins</p>
            </div>

            <div class="services-grid">
                {% set services = [
                    {
                        title: "Petsitting à domicile",
                        description: "Je me déplace chez vous pour garder vos animaux dans leur environnement familier. Chiens, chats, NACs... vos compagnons restent chez eux, en toute sérénité.",
                        price: "À partir de 12€/visite",
                        icon: 'dog'
                    },
                    {
                        title: "Petsitting multi-espèce",
                        description: "Équidés, animaux de mini-ferme, basse-cour… Je m'adapte à tous vos animaux, même les plus atypiques, avec le même soin et la même attention.",
                        price: "Tarif selon espèce",
                        icon: 'farm'
                    },
                    {
                        title: "Naturopathie animalière",
                        description: "Accompagnement naturel pour le bien-être de vos animaux. Consultations en présentiel ou en ligne, avec conseils personnalisés en phytothérapie et nutrition.",
                        price: "70€ présentiel / 60€ en ligne",
                        icon: 'heart'
                    }
                ] %}

                {% for service in services %}
                    <div class="service-card animate-on-scroll" style="--delay: {{ loop.index0 * 0.1 }}s">
                        <div class="service-icon">
                            {% if service.icon == 'dog' %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/>
                                    <path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/>
                                    <path d="M8 14v.5"/>
                                    <path d="M16 14v.5"/>
                                    <path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/>
                                    <path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/>
                                </svg>
                            {% elseif service.icon == 'farm' %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 22V10.5L12 3l9 7.5V22H3z"/>
                                    <path d="M9 22v-6h6v6"/>
                                    <path d="M12 3v4"/>
                                    <path d="M7 13h2"/>
                                    <path d="M15 13h2"/>
                                </svg>
                            {% elseif service.icon == 'heart' %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                </svg>
                            {% else %}
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 20V10"/>
                                    <path d="M18 20V4"/>
                                    <path d="M6 20v-4"/>
                                </svg>
                            {% endif %}
                        </div>
                        <h4 class="service-title">{{ service.title }}</h4>
                        <p class="service-description">{{ service.description }}</p>
                        <p class="service-price">{{ service.price }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Comment ça se passe -->
    <section class="steps-section">
        <div class="container">
            <div class="section-header animate-on-scroll">
                <h3 class="section-title">Comment ça se passe ?</h3>
                <p class="section-subtitle">Simple, humain, sans stress</p>
            </div>
            <div class="steps-grid">
                {% set steps = [
                    {
                        number: "1",
                        title: "On se contacte",
                        text: "On échange par téléphone ou par email pour parler de vos animaux, vos besoins et les dates souhaitées."
                    },
                    {
                        number: "2",
                        title: "Pré-visite",
                        text: "Je viens chez vous faire connaissance avec vos animaux et prendre connaissance de leurs habitudes. Une pré-visite est obligatoire pour les nouveaux clients (10€). Elle permet à tout le monde d'être à l'aise."
                    },
                    {
                        number: "3",
                        title: "Vous partez serein",
                        text: "Le jour J, vos animaux sont gardés chez eux. Je vous envoie des nouvelles régulièrement (photos, messages) pour que vous partiez vraiment tranquille."
                    }
                ] %}
                {% for step in steps %}
                    <div class="step animate-on-scroll" style="--delay: {{ loop.index0 * 0.15 }}s">
                        <div class="step-number">{{ step.number }}</div>
                        <h4 class="step-title">{{ step.title }}</h4>
                        <p class="step-text">{{ step.text }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="tarifs">
        <div class="container-small">
            <div class="section-header animate-on-scroll">
                <h3 class="section-title">Tarifs</h3>
                <p class="section-subtitle">Prestations claires et transparentes</p>
            </div>

            <div class="pricing-accordion animate-on-scroll">

                <!-- Animaux de compagnie -->
                <div class="pricing-acc-item">
                    <button class="pricing-acc-btn" aria-expanded="false">
                        <span class="pricing-acc-label">Animaux de compagnie <small>chiens, chats, NAC</small></span>
                        <span class="pricing-acc-from">à partir de 12€</span>
                        <svg class="pricing-acc-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="pricing-acc-body" hidden>
                        <p class="pricing-acc-note">3 animaux inclus dans le tarif de base. Animal supplémentaire à partir du 4e : +1€.</p>
                        <div class="pricing-acc-rows">
                            <div class="pricing-acc-row"><span>Visite à domicile 30 min</span><span>12€</span></div>
                            <div class="pricing-acc-row"><span>Visite à domicile 45 min</span><span>15€</span></div>
                            <div class="pricing-acc-row"><span>Visite à domicile 60 min</span><span>18€</span></div>
                        </div>
                    </div>
                </div>

                <!-- Mini-ferme -->
                <div class="pricing-acc-item">
                    <button class="pricing-acc-btn" aria-expanded="false">
                        <span class="pricing-acc-label">Mini-ferme / Famille mixte <small>hors équidés</small></span>
                        <span class="pricing-acc-from">à partir de 15€</span>
                        <svg class="pricing-acc-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="pricing-acc-body" hidden>
                        <p class="pricing-acc-note">Tarif sur devis pour les familles mixtes. Animal supplémentaire : +1€.</p>
                        <div class="pricing-acc-rows">
                            <div class="pricing-acc-row"><span>Visite à domicile 30 min</span><span>15€</span></div>
                            <div class="pricing-acc-row"><span>Visite à domicile 45 min</span><span>20€</span></div>
                            <div class="pricing-acc-row"><span>Visite à domicile 60 min</span><span>25€</span></div>
                        </div>
                    </div>
                </div>

                <!-- Equidés -->
                <div class="pricing-acc-item">
                    <button class="pricing-acc-btn" aria-expanded="false">
                        <span class="pricing-acc-label">Equidés <small>chevaux, poneys, ânes</small></span>
                        <span class="pricing-acc-from">à partir de 15€</span>
                        <svg class="pricing-acc-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="pricing-acc-body" hidden>
                        <p class="pricing-acc-note">1 équidé inclus dans le tarif de base. Equidé supplémentaire : +3€.</p>
                        <div class="pricing-acc-rows">
                            <div class="pricing-acc-row"><span>Visite à domicile 30 min</span><span>15€</span></div>
                            <div class="pricing-acc-row"><span>Visite à domicile 60 min</span><span>25€</span></div>
                        </div>
                    </div>
                </div>

                <!-- Naturopathie -->
                <div class="pricing-acc-item">
                    <button class="pricing-acc-btn" aria-expanded="false">
                        <span class="pricing-acc-label">Naturopathie animalière</span>
                        <span class="pricing-acc-from">à partir de 60€</span>
                        <svg class="pricing-acc-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="pricing-acc-body" hidden>
                        <div class="pricing-acc-rows">
                            <div class="pricing-acc-row"><span>Consultation en présentiel</span><span>70€</span></div>
                            <div class="pricing-acc-row"><span>Consultation en ligne</span><span>60€</span></div>
                        </div>
                    </div>
                </div>

                <!-- Suppléments et frais divers -->
                <div class="pricing-acc-item">
                    <button class="pricing-acc-btn" aria-expanded="false">
                        <span class="pricing-acc-label">Suppléments et frais divers</span>
                        <svg class="pricing-acc-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div class="pricing-acc-body" hidden>
                        <div class="pricing-acc-rows">
                            <div class="pricing-acc-row"><span>Majoration dimanche / jours fériés / soirées (22h-00h)</span><span>+3€</span></div>
                            <div class="pricing-acc-row"><span>Frais kilométriques</span><span>0,52€/km (5 premiers offerts)</span></div>
                            <div class="pricing-acc-row"><span>Pré-visite (obligatoire nouveau client)</span><span>10€</span></div>
                            <div class="pricing-acc-row"><span>Rendu des clés (à la demande du client)</span><span>5€</span></div>
                            <div class="pricing-acc-row"><span>Curage abri et enclos</span><span>+5€</span></div>
                            <div class="pricing-acc-row"><span>Pansage et soins</span><span>+5€</span></div>
                            <div class="pricing-acc-row"><span>Gestion des textiles (couvertures, masques...)</span><span>+3€</span></div>
                            <div class="pricing-acc-row"><span>Entrée et sortie box et abri</span><span>+5€</span></div>
                            <div class="pricing-acc-row"><span>Réduction moyenne durée (6e au 10e passage)</span><span>-1€/passage</span></div>
                            <div class="pricing-acc-row"><span>Réduction longue durée (dès le 11e passage)</span><span>-2€/passage</span></div>
                        </div>
                    </div>
                </div>

            </div>

            <p class="pricing-note animate-on-scroll">
                Les tarifs sont exprimés en euros TTC. Sophie Lukomski n'est pas soumise à TVA (article 293 B du CGI).
            </p>
        </div>
    </section>

    <!-- Reviews Section -->
    <section class="reviews-section" id="avis">
        <div class="container">
            <div class="section-header animate-on-scroll">
                <h3 class="section-title">Avis clients</h3>
                <p class="section-subtitle">Ce que disent mes clients</p>
            </div>

            <div class="reviews-grid">
                {% set reviews = [
                    {
                        name: "Yeva",
                        rating: 5,
                        text: "Je recommande Sophie les yeux fermés. J'ai fait appel à ses services de petsitter et tout s'est très bien passé. Nos animaux étaient entre de bonnes mains.",
                        date: "Avis Google"
                    },
                    {
                        name: "Elodie, propriétaire de Foxie et Gaïa",
                        rating: 5,
                        text: "Un week-end, des vacances sans animal, c'est possible en toute confiance avec Sophie. Elle prend soin de nos compagnons comme s'ils étaient les siens.",
                        date: "Avis Google"
                    },
                    {
                        name: "Sandra, éleveuse de Maine Coon",
                        rating: 5,
                        text: "Éleveuse de maine coon, je confie ma chatterie à Sophie lors de mes rares absences. Sérieuse, attentionnée, je repars l'esprit tranquille à chaque fois.",
                        date: "Avis Google"
                    },
                    {
                        name: "Fanny, propriétaire de Heasy",
                        rating: 5,
                        text: "Ma chienne épileptique est suivie par Sophie pour apaiser les effets secondaires de son traitement. Les résultats sont là, je suis vraiment reconnaissante.",
                        date: "Avis Google"
                    }
                ] %}

                {% for review in reviews %}
                    <div class="review-card animate-on-scroll" style="--delay: {{ loop.index0 * 0.1 }}s">
                        <div class="review-stars">
                            {% for i in 1..review.rating %}
                                <svg class="star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
