{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('build/animations.js') }}"></script>
    {% if photos is not empty %}
    <script>
    (function () {
        var track    = document.getElementById('carouselTrack');
        var dotsWrap = document.getElementById('carouselDots');
        var carousel = document.getElementById('photoCarousel');
        if (!track || !carousel) return;

        // Mélange aléatoire (Fisher-Yates)
        var slides = Array.from(track.children);
        var total  = slides.length;
        for (var i = total - 1; i > 0; i--) {
            var j = Math.floor(Math.random() * (i + 1));
            var tmp = slides[i]; slides[i] = slides[j]; slides[j] = tmp;
        }
        slides.forEach(function (s) { track.appendChild(s); });
        slides = Array.from(track.children);

        // Injecter le nombre de slides en variable CSS → le CSS calcule les largeurs
        track.style.setProperty('--carousel-total', total);

        // Points de navigation
        slides.forEach(function (_, idx) {
            var dot = document.createElement('button');
            dot.className = 'carousel-dot' + (idx === 0 ? ' is-active' : '');
            dot.setAttribute('aria-label', 'Photo ' + (idx + 1));
            (function (n) {
                dot.addEventListener('click', function () { stopAuto(); goTo(n); startAuto(); });
            })(idx);
            dotsWrap.appendChild(dot);
        });

        var dots      = Array.from(dotsWrap.children);
        var current   = 0;
        var autoTimer = null;

        function goTo(n) {
            current = ((n % total) + total) % total;
            // translateX en % de la track : -current/total*100% = -current × largeur d'une slide
            track.style.transform = 'translateX(calc(-' + current + ' / ' + total + ' * 100%))';
            dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });
        }

        function next() { goTo(current + 1); }
        function prev() { goTo(current - 1); }

        function startAuto() { autoTimer = setInterval(next, 3000); }
        function stopAuto()  { clearInterval(autoTimer); }

        document.getElementById('carouselNext').addEventListener('click', function () { stopAuto(); next(); startAuto(); });
        document.getElementById('carouselPrev').addEventListener('click', function () { stopAuto(); prev(); startAuto(); });

        carousel.addEventListener('mouseenter', stopAuto);
        carousel.addEventListener('mouseleave', startAuto);

        // Swipe tactile
        var touchStartX = 0;
        carousel.addEventListener('touchstart', function (e) {
            touchStartX = e.touches[0].clientX;
            stopAuto();
        }, { passive: true });
        carousel.addEventListener('touchend', function (e) {
            var dx = touchStartX - e.changedTouches[0].clientX;
            if (Math.abs(dx) > 40) { dx > 0 ? next() : prev(); }
            startAuto();
        }, { passive: true });

        startAuto();
    })();
    </script>
    {% endif %}
{% endblock %}
