{% extends 'base.html.twig' %}

{% block title %}Facture {{ invoice.number }} - Les patounes du glazik{% endblock %}

{% block body %}
<div class="container py-5" style="max-width: 700px;">
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <h2 class="mb-1">Facture {{ invoice.number }}</h2>
          <span class="badge bg-{{ invoice.status.badgeClass() }} fs-6">{{ invoice.status.label() }}</span>
        </div>
        <a href="{{ path('app_invoice_pdf', {id: invoice.id}) }}" class="btn btn-outline-secondary" target="_blank">
          <i class="fa fa-file-pdf"></i> Télécharger PDF
        </a>
      </div>

      <hr>

      <div class="row mb-3">
        <div class="col-6">
          <div class="text-muted small text-uppercase mb-1">Service</div>
          <strong>{{ invoice.booking.serviceType.label() }}</strong>
        </div>
        {% if invoice.booking.scheduledAt %}
        <div class="col-6">
          <div class="text-muted small text-uppercase mb-1">Date de la prestation</div>
          <strong>{{ invoice.booking.scheduledAt|date('d/m/Y à H:i') }}</strong>
        </div>
        {% endif %}
      </div>

      {% if invoice.booking.animal %}
      <div class="mb-3">
        <div class="text-muted small text-uppercase mb-1">Animal</div>
        <strong>{{ invoice.booking.animal.name }}</strong>
      </div>
      {% endif %}

      <div class="d-flex justify-content-between align-items-center bg-light rounded p-3 mb-4">
        <span class="fs-5">Total TTC</span>
        <span class="fs-3 fw-bold text-primary">{{ invoice.amount|number_format(2, ',', ' ') }} €</span>
      </div>

      {% if not invoice.isPaid() %}
      <div class="text-center">
        <button id="pay-btn" class="btn btn-success btn-lg px-5">
          <i class="fa fa-credit-card me-2"></i> Payer par carte
        </button>
        <p class="text-muted small mt-2">Paiement sécurisé via Stripe</p>
      </div>

      <script>
        document.getElementById('pay-btn').addEventListener('click', async () => {
          const btn = document.getElementById('pay-btn');
          btn.disabled = true;
          btn.textContent = 'Redirection...';
          const res = await fetch('{{ path("app_invoice_pay", {id: invoice.id}) }}', { method: 'POST', headers: {'X-Requested-With': 'XMLHttpRequest'} });
          const data = await res.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            alert(data.error || 'Une erreur est survenue.');
            btn.disabled = false;
            btn.textContent = 'Payer par carte';
          }
        });
      </script>
      {% else %}
      <div class="alert alert-success text-center">
        <i class="fa fa-check-circle fa-2x mb-2"></i><br>
        Cette facture a été payée le {{ invoice.paidAt|date('d/m/Y') }}.
      </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
