{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Agenda{% endblock %}

{% block head_stylesheets %}
    {{ parent() }}
    <style>
        #admin-calendar {
            background: #fff;
            border-radius: 10px;
            padding: 1.5rem;
            box-shadow: 0 1px 4px rgba(0,0,0,.08);
        }
        .fc-event { cursor: pointer; font-size: .82rem; }
        .fc-toolbar-title { font-size: 1.1rem !important; font-weight: 600; }
        .calendar-legend { display: flex; gap: 1.5rem; margin-bottom: 1rem; flex-wrap: wrap; }
        .calendar-legend span { display: flex; align-items: center; gap: .4rem; font-size: .85rem; }
        .legend-dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }
    </style>
{% endblock %}

{% block main %}
<div style="padding: 1.5rem;">
    <div class="calendar-legend">
        <span><i class="legend-dot" style="background:#f59e0b"></i> En attente</span>
        <span><i class="legend-dot" style="background:#10b981"></i> Confirmée</span>
        <span><i class="legend-dot" style="background:#6b7280"></i> Terminée</span>
    </div>
    <div id="admin-calendar"></div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('build/admin-calendar.js') }}"></script>
{% endblock %}
