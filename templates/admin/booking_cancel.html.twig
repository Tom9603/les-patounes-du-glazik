{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Annuler la réservation #{{ booking.id }}{% endblock %}

{% block main %}
<div class="card">
    <div class="card-header">
        <h2>Annuler la réservation #{{ booking.id }}</h2>
        <p class="text-muted">Client : {{ booking.client }} &mdash; Service : {{ booking.serviceType.label() }}</p>
        <p class="text-muted">Date souhaitée : {{ booking.preferredDate|date('d/m/Y') }}</p>
    </div>
    <div class="card-body">

        {% if booking.invoices is not empty %}
            {% for invoice in booking.invoices %}
                {% if invoice.isPaid() %}
                <div class="alert alert-info">
                    <strong>Remboursement automatique :</strong> la facture {{ invoice.number }} ({{ invoice.amount|number_format(2, ',', ' ') }} €) est payée.
                    Le remboursement Stripe sera déclenché automatiquement.
                </div>
                {% endif %}
            {% endfor %}
        {% endif %}

        <form method="post" action="{{ path('app_booking_admin_cancel', { id: booking.id }) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('booking-cancel-' ~ booking.id) }}">

            <div class="mb-3">
                <label class="form-label">Motif de l'annulation (sera communiqué au client)</label>
                <textarea name="reason" class="form-control" rows="4" placeholder="Ex : Indisponibilité imprévue, contrainte personnelle..."></textarea>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger">
                    <i class="fa fa-ban"></i> Confirmer l'annulation
                </button>
                <a href="{{ path('admin', { crudControllerFqcn: 'App\\Controller\\Admin\\BookingCrudController', crudAction: 'index' }) }}" class="btn btn-secondary">Retour</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
