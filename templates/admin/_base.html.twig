<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block page_title '' %} | Admin - Les patounes du glazik</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body { background: #1a1a2e; color: #e0e0e0; min-height: 100vh; }
        .admin-sidebar { background: #16213e; width: 220px; min-height: 100vh; position: fixed; top: 0; left: 0; padding: 1rem 0; z-index: 100; }
        .admin-sidebar .brand { color: #fff; font-weight: bold; padding: .75rem 1.25rem; font-size: 1rem; border-bottom: 1px solid #2a2a4a; margin-bottom: .5rem; }
        .admin-sidebar a { display: block; padding: .5rem 1.25rem; color: #b0b8d0; text-decoration: none; font-size: .88rem; }
        .admin-sidebar a:hover, .admin-sidebar a.active { background: #0f3460; color: #fff; }
        .admin-sidebar .nav-section { font-size: .7rem; text-transform: uppercase; letter-spacing: .08em; color: #5a6a8a; padding: 1rem 1.25rem .25rem; }
        .admin-main { margin-left: 220px; padding: 1.5rem 2rem; }
        .admin-topbar { background: #16213e; border-bottom: 1px solid #2a2a4a; padding: .5rem 2rem; margin-left: 220px; position: sticky; top: 0; z-index: 50; display: flex; justify-content: flex-end; align-items: center; gap: 1rem; }
        .admin-topbar a { color: #b0b8d0; font-size: .85rem; text-decoration: none; }
        .admin-topbar a:hover { color: #fff; }
        .card { background: #16213e; border: 1px solid #2a2a4a; color: #e0e0e0; }
        .table { color: #e0e0e0; }
        .table td, .table th { border-color: #2a2a4a; }
        .table-hover tbody tr:hover { background: #1e2d50; color: #e0e0e0; }
        .form-control, .form-select { background: #0f3460; border-color: #2a2a4a; color: #e0e0e0; }
        .form-control:focus, .form-select:focus { background: #0f3460; color: #fff; border-color: #4a9eff; }
    </style>
</head>
<body>

<nav class="admin-sidebar">
    <div class="brand"><i class="fa fa-paw me-2"></i>Les patounes</div>
    <div class="nav-section">Contenu</div>
    <a href="{{ path('admin', {crudControllerFqcn: 'App\\Controller\\Admin\\PhotoCrudController', crudAction: 'index'}) }}"><i class="fa fa-images me-2"></i>Galerie photos</a>
    <div class="nav-section">Réservations</div>
    <a href="{{ path('app_admin_calendar') }}"><i class="fa fa-calendar me-2"></i>Agenda</a>
    <a href="{{ path('admin', {crudControllerFqcn: 'App\\Controller\\Admin\\BookingCrudController', crudAction: 'index'}) }}"><i class="fa fa-calendar-check me-2"></i>Réservations</a>
    <a href="{{ path('app_admin_invoice_index') }}" class="{{ app.request.attributes.get('_route') starts with 'app_admin_invoice' ? 'active' : '' }}"><i class="fa fa-file-invoice me-2"></i>Factures</a>
    <div class="nav-section">Analytique</div>
    <a href="{{ path('app_admin_stats') }}"><i class="fa fa-chart-bar me-2"></i>Statistiques</a>
    <div class="nav-section">Paramètres</div>
    <a href="{{ path('admin', {crudControllerFqcn: 'App\\Controller\\Admin\\UserCrudController', crudAction: 'index'}) }}"><i class="fa fa-users me-2"></i>Utilisateurs</a>
</nav>

<div class="admin-topbar">
    <a href="{{ path('app_home') }}" target="_blank"><i class="fa fa-eye me-1"></i>Voir le site</a>
    <span class="text-muted">{{ app.user.firstName ?? app.user.email }}</span>
</div>

<main class="admin-main">
    {% for msg in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    {% endfor %}

    {% block main %}{% endblock %}
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
