{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}Refuser la réservation #{{ booking.id }}{% endblock %}

{% block main %}
<div class="card">
    <div class="card-header">
        <h2>Refuser la réservation #{{ booking.id }}</h2>
        <p class="text-muted">Client : {{ booking.client }} &mdash; Service : {{ booking.serviceType.label() }}</p>
        <p class="text-muted">Date souhaitée : {{ booking.preferredDate|date('d/m/Y') }}</p>
    </div>
    <div class="card-body">
        <form method="post" action="{{ path('app_booking_admin_refuse', { id: booking.id }) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('booking-refuse-' ~ booking.id) }}">

            <div class="mb-3">
                <label class="form-label">Motif du refus (sera communiqué au client)</label>
                <textarea name="reason" class="form-control" rows="4" placeholder="Ex : Indisponible à cette date, zone hors secteur..."></textarea>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-danger">
                    <i class="fa fa-times"></i> Confirmer le refus
                </button>
                <a href="{{ path('admin', { crudControllerFqcn: 'App\\Controller\\Admin\\BookingCrudController', crudAction: 'index' }) }}" class="btn btn-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
